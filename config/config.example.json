{
    "api": {
      "port": 8000,
      "host": "0.0.0.0",
      "auth_token": "your-auth-token-here"
    },
    "tikhub": {
      "api_key": "your-tikhub-api-key-here",
      "max_retries": 2,
      "retry_delay": 5,
      "timeout": 30
    },
    "capswriter": {
      "path": "./CapsWriter-Offline",
      "server_url": "ws://localhost:6016",
      "max_retries": 5,
      "retry_delay": 3,
      "connection_timeout": 10
    },
    "concurrent": {
      "max_workers": 3,
      "queue_size": 10
    },
    "storage": {
      "temp_dir": "./temp",
      "output_dir": "./output",
      "cache_dir": "./cache_dir",
      "cache_retention_days": 360
    },
    "web": {
      "base_url": "http://localhost:8000",
      "enable_view_links": true,
      "timezone": "UTC+8"
    },
    "wechat": {
      "webhook": "your-webhook-url-here"
    },
    "bbdown": {
      "use_bbdown": true,
      "executable": "BBDown/BBDown.exe",
      "executable_linux": "BBDown/BBDown",
      "audio_only": true,
      "timeout": 300
    },
    "log": {
      "level": "INFO",
      "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
      "file": "./data/logs/app.log",
      "debug_dir": "./data/logs/debug",
      "llm_debug_dir": "./data/logs/llm_debug",
      "max_size": 10485760,
      "backup_count": 5
    },
    "llm": {
      "api_key": "your-llm-api-key-here",
      "base_url": "your-base-url-here",
      "calibrate_model": "gpt-4.1-mini",
      "calibrate_reasoning_effort": null,
      "summary_model": "deepseek-chat",
      "summary_reasoning_effort": "high",
      "max_retries": 2,
      "retry_delay": 5,
      "segmentation": {
        "enable_threshold": 20000,
        "segment_size": 8000,
        "max_segment_size": 12000,
        "concurrent_workers": 10
      },
      "structured_calibration": {
        "min_chunk_length": 800,
        "max_chunk_length": 3000,
        "preferred_chunk_length": 2000,
        "max_calibration_retries": 2,
        "calibration_concurrent_limit": 10,
        "quality_threshold": {
          "overall_score": 8.0,
          "minimum_single_score": 7.0
        },
        "enable_validation": true,
        "fallback_to_original": true,
        "validator_model": "gpt-4.1-mini",
        "validator_reasoning_effort": null
      }
    },
    "funasr_spk_server": {
      "server_url": "ws://localhost:8767",
      "max_retries": 3,
      "retry_delay": 5,
      "connection_timeout": 30
    },
    "risk_control": {
      "enabled": false,
      "sensitive_word_urls": [
        "https://raw.githubusercontent.com/konsheng/Sensitive-lexicon/refs/heads/main/Vocabulary/%E6%96%B0%E6%80%9D%E6%83%B3%E5%90%AF%E8%92%99.txt"
      ],
      "cache_file": "./data/risk_control/sensitive_words.txt"
    }
  } 