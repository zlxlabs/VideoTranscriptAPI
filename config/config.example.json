{
    "api": {
      "port": 8000,
      "host": "0.0.0.0",
      "auth_token": "your-auth-token-here"
    },
    "tikhub": {
      "api_key": "your-tikhub-api-key-here",
      "max_retries": 2,
      "retry_delay": 5,
      "timeout": 30
    },
    "capswriter": {
      "path": "./CapsWriter-Offline",
      "server_url": "ws://localhost:6016",
      "max_retries": 5,
      "retry_delay": 3,
      "connection_timeout": 10
    },
    "concurrent": {
      "max_workers": 3,
      "queue_size": 10
    },
    "storage": {
      "temp_dir": "./temp",
      "output_dir": "./output",
      "cache_dir": "./cache_dir",
      "cache_retention_days": 360
    },
    "web": {
      "base_url": "http://localhost:8000",
      "enable_view_links": true,
      "timezone": "UTC+8"
    },
    "wechat": {
      "webhook": "your-webhook-url-here"
    },
    "log": {
      "level": "INFO",
      "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
      "file": "./data/logs/app.log",
      "debug_dir": "./data/logs/debug",
      "llm_debug_dir": "./data/logs/llm_debug",
      "max_size": 10485760,
      "backup_count": 5
    },
    "llm": {
      "api_key": "your-llm-api-key-here",
      "base_url": "your-base-url-here",
      "calibrate_model": "gpt-4.1-mini",
      "summary_model": "deepseek-chat"
    },
    "funasr_spk_server": {
      "server_url": "ws://localhost:8767",
      "max_retries": 3,
      "retry_delay": 5,
      "connection_timeout": 30
    },
    "risk_control": {
      "enabled": false,
      "sensitive_word_urls": [
        "https://raw.githubusercontent.com/konsheng/Sensitive-lexicon/refs/heads/main/Vocabulary/%E6%96%B0%E6%80%9D%E6%83%B3%E5%90%AF%E8%92%99.txt"
      ],
      "cache_file": "./data/risk_control/sensitive_words.txt"
    }
  } 